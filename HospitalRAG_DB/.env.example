DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=hospital_rag
DB_USER=rag_app
DB_PASSWORD=rag_app_pw

# Local by default -- no key needed. Set these to switch to OpenAI:
#   EMBEDDING_PROVIDER=openai
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
# See docs/02_er_diagram.md for why changing EMBEDDING_PROVIDER after
# documents are already ingested requires re-ingesting them.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=local
LOCAL_LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
OPENAI_API_KEY=
